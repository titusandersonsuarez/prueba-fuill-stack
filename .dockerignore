# Dependencies (will be re-installed inside the image)
node_modules
**/node_modules

# Build artifacts (will be generated inside the image)
**/dist
**/.next
!**/.next/cache

# Local environment files with secrets — including nested ones like
# apps/api/.env. A bare `.env` pattern does NOT match nested paths in
# .dockerignore, so without `**/` the local secrets leak into the build
# context and a local DATABASE_URL can shadow the real one.
**/.env
**/.env.local
**/.env.*.local
# Keep .env.example — no secrets, just documentation

# Version control
.git
.gitignore
.gitattributes

# Editor & OS
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test coverage
**/coverage

# CI / GitHub
.github

# Turbo cache
.turbo

# Misc
*.md
docs/
